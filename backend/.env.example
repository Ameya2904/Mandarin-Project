MONGO_URL="mongodb://localhost:27017"
DB_NAME="mandarin_app"
JWT_SECRET_KEY="change-me-to-a-long-random-string"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# Speech-to-text (FunASR, runs locally on the server)
ASR_MODEL="FunAudioLLM/Fun-ASR-Nano-2512"
ASR_HUB="hf"          # "hf" (HuggingFace) or "ms" (ModelScope)
ASR_DEVICE="cpu"      # "cpu" or "cuda:0" if the VM has a GPU
ASR_LANGUAGE="中文"    # 中文 / English / 日本語
